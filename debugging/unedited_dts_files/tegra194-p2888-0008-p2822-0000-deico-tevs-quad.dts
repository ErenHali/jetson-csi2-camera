// SER1 -> CAM1 starts here
&des_1_i2c_0 {

	ser_1: gmsl-serializer@1c {
		status = "okay";
		#address-cells = <1>;
		#size-cells = <0>;
		compatible = "maxim,max96717";
		reg = <0x1c>;

		// i2c addr alias map "isp, gpio expander"
		i2c-addr-alias-map-local = <0x1e 0x1d>;	// virtual I2C addresses assigned to the devices
		i2c-addr-alias-map-remote = <0x48 0x25>;// actual I2C addresses of the devices

		gpio-controller;
		#gpio-cells = <2>;
		gpio-ranges = <&ser_1 0 0 11>;
		// Uncomment below to activate tunnel-mode otherwise, pixel-mode is selected
		//maxim,tunnel-mode;

		pinctrl-names = "default";
		pinctrl-0 = <&ser_1_pinmux_default>;

		ser_1_pinmux_default: pinmux {
			mfp0_fsync {
				pins = "mfp0";
				function = "gpio";
				maxim,gmsl-rx = <1>;
				maxim,gmsl-rx-id = <0>;
				output-enable;
				output-low;
			};
		};

		i2c-mux {
			#address-cells = <1>;
			#size-cells = <0>;

			compatible = "i2c-mux-gpio";
			i2c-parent = <&cam_i2c>;

			ser_1_i2c_0: i2c@0 {
				#address-cells = <1>;
				#size-cells = <0>;

				reg = <0>;
			};
		};

		pipe@0 {
			reg = <0>;

			maxim,stream-id = <0>;
		};

		channel@0 {
			reg = <0>;
			label = "ser_1_ch_0";

			clock-lanes = <0>;
			data-lanes = <1 2 3 4>;
			clock-noncontinuous;
		};
	};
};

