// File: tegra194-p2888-0008-p2822-0000-deico-tevs-quad.dts

/dts-v1/;

#include "tegra194-p2888-0008-p2822-0000.dts"

#define CAM_LANES 			4          // number of CSI lanes used by each camera
#define CAM_LANES_STRING 	"4"
#define GMSL_CAM_NUM 		1	       // equals to number of cameras can be connected to your board
#define TOTAL_CSI_LANES 	(GMSL_CAM_NUM * CAM_LANES)
#define DES_LINK_FREQ 		1000000000 // min: 100000000, max: 1250000000, currently: 1GHz
#define CSI_FREQ 			500        // min: 100, max: 1200

/ {
	/*
	 * This is a new, virtual regulator definition that describes the
	 * discrete, always-on 1.8V power supply for our camera components.
	 * It does not control any hardware, it just provides a valid
	 * handle for drivers that require a power supply dependency.
	 */
	fixed-regulators {

		cam_vcc_1v8_reg: fixed-regulator-cam-1v8 {
			compatible = "regulator-fixed";
			regulator-name = "fixed-1.8v-cam-power";
			regulator-min-microvolt = <1800000>;
			regulator-max-microvolt = <1800000>;
			regulator-always-on;
		};
	};
};


&capture_vi_base { // /tegra-capture-vi
	status = "okay";
	num-channels = <4>;

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@2 {
			status = "okay";
			
			endpoint {	// vi_in2
				port-index = <4>;
				bus-width = <CAM_LANES>;
				remote-endpoint = <&csi_out2>;
				vc-id = <0x00>;
				status = "okay";
			};
		};
	};
};

&nvcsi { // /host1x@13e00000/nvcsi@15a00000
	status = "okay";
	num-channels = <4>;
	
	channel@2 {
		status = "okay";

		ports {

			port@0 { // Sink port
				status = "okay";

				endpoint@4 {	// csi_in2
					port-index = <4>;
					bus-width = <CAM_LANES>;
					remote-endpoint = <&rpi22_tevs_2_out>;
					status = "okay";
				};
			};

			port@1 { // Source port
				status = "okay";

				endpoint@5 {	//csi_out2
					remote-endpoint = <&vi_in2>;
					status = "okay";
				};
			};
		};
	};
};

&tcp { // /tegra-camera-platform
	num_csi_lanes = <TOTAL_CSI_LANES>;	// total number of CSI lanes used by all cameras (4x1)
	max_lane_speed = <4000000>;
	min_bits_per_pixel = <16>;			// only this is updated
	vi_peak_byte_per_pixel = <2>;
	vi_bw_margin_pct = <25>;
	//max_pixel_rate = <240000>;
	//isp_peak_byte_per_pixel = <5>;
	//isp_bw_margin_pct = <25>;

	modules {

		module2 {
			badge = "tevs_left";
			position = "left";
			//orientation = "1";
			status = "okay";

			drivernode0 {
				pcl_id = "v4l2_sensor";
				devname = "VLS-GM2-AR0234-Camera-3";
				proc-device-tree = "/proc/device-tree/i2c@3180000/gmsl-deserializer@2b/i2c@0/gmsl-serializer@2c/i2c@0/rpi22_tevs_2@2e";
				status = "okay";
			};
		};
	};
};

&cam_i2c { // /i2c@31800000
	status = "okay";

	des_2: gmsl-deserializer@0x2b {

		status = "okay";
		#address-cells = <1>;
		#size-cells = <0>;
		compatible = "maxim,max96714";
		reg = <0x2b>;
		phy-reg = <0x4c>; // deserializer power-on I2C address

		i2c-addr-alias-map-local = <0x2c>;		// virtual I2C addresses assigned to the serializer
		i2c-addr-alias-map-remote = <0x40>; 	// actual I2C address of the serializer
		i2c-addr-alias-source-id = <0>;

		gpio-controller;
		#gpio-cells = <2>;
		gpio-ranges = <&des_2 0 0 12>;

		pinctrl-names = "default";
		pinctrl-0 = <&des_2_pinmux_default>;

		// fsync-mode = "external";

		des_2_pinmux_default: pinmux {
			mfp0_fsync {
				pins = "mfp0";
				function = "gpio";
				maxim,gmsl-tx = <1>;
				maxim,gmsl-tx-id = <0>;
				input-enable;
			};
		};

		i2c-mux { 

			#address-cells = <1>;
			#size-cells = <0>;

			compatible = "i2c-mux-gpio";
			i2c-parent = <&cam_i2c>;

			des_2_i2c_0: i2c@0 {
				#address-cells = <1>;
				#size-cells = <0>;

				reg = <0>;
			};
		};

		phy@0 {
			reg = <0>;
		};

		pipe@0 {
			reg = <0>;

			maxim,phy-id = <0>;
		};

		channel@0 {
			reg = <0>;
			label = "des_2_ch_0";

			maxim,phy-id = <0>;

			clock-lanes = <0>;
			data-lanes = <1 2 3 4>;
			link-frequencies = /bits/ 64 <DES_LINK_FREQ>;
		};
	};
};

// SER2 -> CAM2 starts here
&des_2_i2c_0 {

	ser_2: gmsl-serializer@2c {
		status = "okay";
		#address-cells = <1>;
		#size-cells = <0>;
		compatible = "maxim,max96717";
		reg = <0x2c>;

		// i2c addr alias map "isp, gpio expander"
		i2c-addr-alias-map-local = <0x2e 0x2d>;	// virtual I2C addresses assigned to the devices
		i2c-addr-alias-map-remote = <0x48 0x25>;// actual I2C addresses of the devices

		gpio-controller;
		#gpio-cells = <2>;
		gpio-ranges = <&ser_2 0 0 11>;

		pinctrl-names = "default";
		pinctrl-0 = <&ser_2_pinmux_default>;

		ser_2_pinmux_default: pinmux {
			mfp0_fsync {
				pins = "mfp0";
				function = "gpio";
				maxim,gmsl-rx = <1>;
				maxim,gmsl-rx-id = <0>;
				output-enable;
				output-low;
			};
		};

		i2c-mux {
			#address-cells = <1>;
			#size-cells = <0>;

			compatible = "i2c-mux-gpio";
			i2c-parent = <&cam_i2c>;

			ser_2_i2c_0: i2c@0 {
				#address-cells = <1>;
				#size-cells = <0>;

				reg = <0>;
			};
		};

		pipe@0 {
			reg = <0>;

			maxim,stream-id = <0>;
		};

		channel@0 {
			reg = <0>;
			label = "ser_2_ch_0";

			clock-lanes = <0>;
			data-lanes = <1 2 3 4>;
			clock-noncontinuous;
		};
	};
};

&ser_2_i2c_0 {
	pca9554_cam_2: pca9554@2d {
		compatible = "nxp,pca9554";
		reg = <0x2d>;
		gpio-controller;
		#gpio-cells = <2>;
		gpio-line-names = "EXPOSURE_TRIG_IN",
						"FLASH_OUT",
						"INFO_TRIG_IN",
						"CAMA_SHUTTER",
						"CSI_P1_nRST",
						"PWR_TIME0",
						"PWR_TIME1",
						"3V3_EN";
		vcc-supply = <&cam_vcc_1v8_reg>;
		vcc_lp = "vcc";
		status = "okay";
	};

	cam_2: rpi22_tevs_2@2e {
		compatible = "tn,tevs";
		reg = <0x2e>;
		status = "okay";

		reset-gpios = <&pca9554_cam_2 4 GPIO_ACTIVE_HIGH>;
		standby-gpios = <&pca9554_cam_2 2 GPIO_ACTIVE_HIGH>;
		data-lanes = <CAM_LANES>;
		data-frequency = <CSI_FREQ>;

		/* V4L2 device node location */
		devnode = "video0";
		/* Physical dimensions of sensor */
		physical_w = "3.680";
		physical_h = "2.760";
		sensor_model = "tevs";
		use_sensor_mode_id = "false";

		mode0 {
			mclk_khz = "24000";
			num_lanes = CAM_LANES_STRING;
			tegra_sinterface = "serial_e";
			phy_mode = "DPHY";
			discontinuous_clk = "yes";
			dpcm_enable = "false";
			cil_settletime = "0";

			active_w = "3280";
			active_h = "2464";
			mode_type = "yuv";
			pixel_phase = "uyvy";
			csi_pixel_bit_depth = "16";
			readout_orientation = "90";
			line_length = "3448";
			inherent_gain = "1";
			mclk_multiplier = "9.33";
			pix_clk_hz = "200000000";
			serdes_pix_clk_hz = "500000000";

			gain_factor = "16";
			framerate_factor = "1000000";
			exposure_factor = "1000000";
			min_gain_val = "16"; /* 1.00x */
			max_gain_val = "170"; /* 10.66x */
			step_gain_val = "1";
			default_gain = "16"; /* 1.00x */
			min_hdr_ratio = "1";
			max_hdr_ratio = "1";
			min_framerate = "2000000"; /* 2.0 fps */
			max_framerate = "21000000"; /* 21.0 fps */
			step_framerate = "1";
			default_framerate = "21000000"; /* 21.0 fps */
			min_exp_time = "13"; /* us */
			max_exp_time = "683709"; /* us */
			step_exp_time = "1";
			default_exp_time = "2495"; /* us */
			embedded_metadata_height = "0";
		};
		mode1 {
			mclk_khz = "24000";
			num_lanes = CAM_LANES_STRING;
			tegra_sinterface = "serial_e";
			phy_mode = "DPHY";
			discontinuous_clk = "yes";
			dpcm_enable = "false";
			cil_settletime = "0";

			active_w = "3280";
			active_h = "1848";
